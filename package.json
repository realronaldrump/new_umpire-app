{
  "name": "big-beautiful-umpire-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "vite",
    "dev:worker": "wrangler dev --port 8787",
    "dev:multiplayer": "concurrently -k -n WEB,ROOMS -c cyan,yellow \"npm:dev -- --port 5175\" \"npm:dev:worker\"",
    "build": "npm run typecheck && npm run typecheck:worker && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:worker": "vitest run --config vitest.worker.config.ts",
    "test:e2e": "playwright test",
    "test:all": "npm test && npm run test:worker",
    "typecheck": "tsc --noEmit",
    "typecheck:worker": "tsc -p tsconfig.worker.json --noEmit",
    "deploy:worker": "wrangler deploy"
  },
  "dependencies": {
    "@fontsource/archivo": "^5.2.8",
    "@fontsource/bebas-neue": "^5.2.7",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@cloudflare/workers-types": "^5.20260711.1",
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
